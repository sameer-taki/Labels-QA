# Golden QA App - environment template.
#
# Copy this file to ".env" (next to the compose files) and fill in real values:
#     cp .env.example .env
#
# ".env" holds SECRETS and is git-ignored - never commit it. The compose files read
# these variables; in Portainer you can paste the same key=value pairs into the stack's
# environment instead of using a .env file.
#
# Required variables fail fast (the stack refuses to start) if left blank.
#
# ============================================================================================
# CLOUD DEPLOYMENT (Vercel + Supabase + Clerk) — see CLOUD-DEPLOY.md
# Set these in the Vercel project's Environment Variables (Project → Settings → Environment
# Variables), NOT in a committed file. The on-prem variables further below are unused in the
# cloud deploy (Clerk replaces AD/Entra; Supabase Storage replaces local uploads; Supabase
# Postgres is the system of record; Vercel Cron replaces the timers).
# --------------------------------------------------------------------------------------------
# Supabase Postgres — use the SESSION-mode pooler string (port 5432). Session pooling pins a
# client to one backend, which the write-serialising advisory lock requires. Replace
# [YOUR-PASSWORD] with the project's database password.
#   DATABASE_URL=postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres
# Optional: share one Supabase project with another app by giving this app its own state table.
#   PG_STATE_TABLE=app_state
#
# Supabase Storage — for photo/signature uploads.
#   SUPABASE_URL=https://<ref>.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=<service_role secret from Supabase → Settings → API>
#   SUPABASE_STORAGE_BUCKET=qa-uploads
#
# Clerk — sign-in (identity). Roles stay in this app, matched to Clerk users by e-mail.
#   CLERK_PUBLISHABLE_KEY=pk_live_xxx      (or pk_test_xxx)
#   CLERK_SECRET_KEY=sk_live_xxx           (or sk_test_xxx)
#   CLERK_ALLOWED_DOMAIN=golden.com.fj     (optional: restrict sign-in to this e-mail domain)
#
# First-admin bootstrap: the seed admin is matched to a Clerk account by this e-mail on first
# sign-in, so the first person can sign in via Clerk and then manage users in-app.
#   ADMIN_USERNAME=admin
#   ADMIN_PASSWORD=<strong password — also the break-glass local login>
#   ADMIN_EMAIL=<your Clerk sign-in e-mail, e.g. sameer@golden.com.fj>
#
# Vercel Cron auth — Vercel sends this as a Bearer token to /api/cron.
#   CRON_SECRET=<48-byte random>
#
# NODE_ENV=production is set automatically by Vercel. SECRET_KEY (below) is still required.
# ============================================================================================

# Public hostname Traefik routes to. PRODUCTION (docker-compose.traefik.yml) only;
# unused by the standalone docker-compose.yml. Must have a DNS record pointing at the host.
APP_HOST=goldenqa.gml.com.fj

# Postgres password for the 'goldenqa' user/database. Pick a strong value.
# IMPORTANT: this MUST stay constant for the life of the goldenqa_pgdata volume - changing
# it after the DB is initialised will NOT update the stored password and the app will fail
# to connect. To change it you must reset the volume (and lose data) or ALTER it inside psql.
DB_PASSWORD=change-me-strong-db-password

# Session/token signing secret. The app refuses to start in production without a strong value.
# Generate one with:
#   docker run --rm node:24-slim node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SECRET_KEY=change-me-generate-a-48-byte-random-secret

# Seed admin account, created on the FIRST run against an empty database.
# ADMIN_USERNAME is optional (defaults to 'admin'). ADMIN_PASSWORD is REQUIRED in production
# (the app refuses to seed an empty DB without it).
ADMIN_USERNAME=admin
# Set a strong password; change it from the admin panel after first login.
ADMIN_PASSWORD=change-me-strong-admin-password

# Optional: timezone for container logs and the nightly backup schedule (IANA name).
# Defaults to Pacific/Fiji if left unset.
TZ=Pacific/Fiji

# ---- Manager e-mail notifications (SMTP) -----------------------------------------
# Turn this on to e-mail managers/supervisors when a checklist is completed/verified,
# on hold/reject alerts, and the digest. Leave SMTP_HOST blank to keep e-mail OFF
# (the app just no-ops). Recipients = Supervisors/QM/Admins who have an e-mail on their
# account, plus NOTIFY_EMAIL_TO below.
#
# SMTP_HOST turns e-mail on. For an internal relay that accepts unauthenticated mail from
# the host, SMTP_HOST (+ SMTP_FROM) is enough. For an authenticated relay, also set
# SMTP_USER/SMTP_PASS. Use SMTP_SECURE=true for implicit TLS (port 465); leave false for
# STARTTLS (587).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=golden-qa@golden.com.fj
# Comma-separated always-notify recipients (managers/supervisors), in addition to users
# who have an e-mail set on their account.
NOTIFY_EMAIL_TO=
# Optional: skip TLS cert verification for a relay with a self-signed cert (default: verify).
# SMTP_REJECT_UNAUTHORIZED=false

# Optional: Microsoft Teams incoming-webhook URL — mirrors the same alerts to a Teams channel.
TEAMS_WEBHOOK_URL=

# ---- Local Active Directory sign-in (LDAPS) --------------------------------------
# Users sign in with their AD username + password; the server verifies them against a
# domain controller and maps their AD security groups to app roles. A local break-glass
# admin (ADMIN_USERNAME/ADMIN_PASSWORD above) always works even if the DC is unreachable.
# Turn it on with LDAP_ENABLED=true, then set the rest here and the group->role mapping
# in config.json (ldap.roleGroups). See deploy/AD-SSO-SETUP.md.
LDAP_ENABLED=false
# Domain controller URL. Use ldaps:// (TLS) in production; ldap://:389 only on a trusted LAN.
LDAP_URL=ldaps://dc.golden.local:636
# Search base for user lookups.
LDAP_BASE_DN=DC=golden,DC=local
# Read-only service account used to find a user before verifying their password. Provide a DN
# (CN=svc-goldenqa,OU=Service Accounts,DC=golden,DC=local) or UPN (svc-goldenqa@golden.local).
# Keep the password out of config.json — set it here.
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=change-me-service-account-password
